{
    "name": "meetily",
    "version": "0.5.0",
    "private": true,
    "packageManager": "pnpm@11.7.0",
    "engines": {
        "node": ">=22.18.0 <23",
        "pnpm": "11.7.0"
    },
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev -p 3118",
        "build": "node scripts/clean-next-output.mjs && next build",
        "export": "next export",
        "start": "next start -p 3118",
        "tauri": "tauri",
        "tauri:dev": "node scripts/tauri-auto.js dev",
        "tauri:build": "node scripts/tauri-auto.js build",
        "tauri:dev:cpu": "tauri dev",
        "tauri:dev:cuda": "tauri dev -- --features cuda",
        "tauri:dev:vulkan": "tauri dev -- --features vulkan",
        "tauri:dev:metal": "tauri dev -- --features metal",
        "tauri:dev:qa": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=routes tauri dev --config src-tauri/tauri.qa.routes.conf.json -- --features metal",
        "tauri:dev:qa:minimum": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=routes tauri dev --config src-tauri/tauri.qa.minimum.conf.json -- --features metal",
        "tauri:dev:qa:onboarding": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=onboarding tauri dev --config src-tauri/tauri.qa.onboarding.conf.json -- --features metal",
        "tauri:dev:coreml": "tauri dev -- --features coreml",
        "tauri:dev:openblas": "tauri dev -- --features openblas",
        "tauri:dev:hipblas": "tauri dev -- --features hipblas",
        "tauri:build:cpu": "tauri build",
        "tauri:build:cuda": "tauri build -- --features cuda",
        "tauri:build:vulkan": "tauri build -- --features vulkan",
        "tauri:build:metal": "tauri build -- --features metal",
        "tauri:build:qa": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=routes tauri build --debug --bundles app --config src-tauri/tauri.qa.routes.conf.json --features metal",
        "tauri:build:qa:minimum": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=routes tauri build --debug --bundles app --config src-tauri/tauri.qa.minimum.conf.json --features metal",
        "tauri:build:qa:onboarding": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=onboarding tauri build --debug --bundles app --config src-tauri/tauri.qa.onboarding.conf.json --features metal",
        "tauri:build:coreml": "tauri build -- --features coreml",
        "tauri:build:openblas": "tauri build -- --features openblas",
        "tauri:build:hipblas": "tauri build -- --features hipblas",
        "lint": "eslint src --max-warnings 0",
        "lint:strict": "eslint src --config eslint.strict.config.mjs --max-warnings 0",
        "typecheck": "tsc --noEmit",
        "test:rendered": "vitest run",
        "test:rendered:watch": "vitest",
        "test:e2e:browser": "node scripts/run-browser-e2e.mjs",
        "test:e2e:browser:update": "node scripts/run-browser-e2e.mjs --update",
        "tauri:build:wdio": "NEXT_PUBLIC_MEETILY_NATIVE_QA_MODE=routes NEXT_PUBLIC_MEETILY_WDIO=true tauri build --debug --no-bundle --config src-tauri/tauri.qa.wdio.conf.json --features wdio,metal",
        "test:e2e:native": "wdio run tests/e2e/wdio.native.conf.mjs",
        "test:e2e:native:update": "MEETILY_UPDATE_VISUALS=1 wdio run tests/e2e/wdio.native.conf.mjs",
        "audit:prod": "pnpm audit --prod --audit-level low",
        "check:bundle": "node scripts/check-route-bundle-budget.mjs"
    },
    "dependencies": {
        "@blocknote/core": "0.36.0",
        "@blocknote/react": "0.36.0",
        "@blocknote/shadcn": "0.36.0",
        "@heroicons/react": "^2.2.0",
        "@hookform/resolvers": "^5.1.1",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-scroll-area": "^1.2.9",
        "@radix-ui/react-select": "^2.2.5",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.5",
        "@radix-ui/react-tabs": "^1.1.12",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-virtual": "^3.13.13",
        "@tauri-apps/api": "^2.6.0",
        "@tauri-apps/plugin-os": "^2.3.2",
        "@tauri-apps/plugin-process": "^2.3.0",
        "@tauri-apps/plugin-store": "^2.4.0",
        "@tauri-apps/plugin-updater": "^2.3.0",
        "@tiptap/pm": "^2.10.4",
        "@types/lodash": "^4.17.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^11.15.0",
        "lodash": "^4.17.21",
        "next": "15.5.20",
        "radix-ui": "^1.4.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hook-form": "^7.59.0",
        "react-markdown": "^9.0.1",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.3.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.25.71"
    },
    "devDependencies": {
        "@axe-core/webdriverio": "4.12.1",
        "@eslint/eslintrc": "3.3.6",
        "@tailwindcss/typography": "^0.5.15",
        "@tauri-apps/cli": "^2.1.0",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "^20",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "6.0.3",
        "@wdio/cli": "9.29.1",
        "@wdio/globals": "9.29.1",
        "@wdio/local-runner": "9.29.1",
        "@wdio/mocha-framework": "9.29.1",
        "@wdio/spec-reporter": "9.29.1",
        "@wdio/tauri-plugin": "1.2.0",
        "@wdio/tauri-service": "1.2.0",
        "@wdio/visual-service": "10.1.0",
        "autoprefixer": "^10.0.1",
        "axe-core": "4.12.1",
        "eslint": "9.39.2",
        "eslint-config-next": "15.5.20",
        "jsdom": "29.1.1",
        "postcss": "^8",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.7.2",
        "vitest": "4.1.10",
        "wait-on": "9.0.10",
        "webdriverio": "9.29.1"
    }
}
