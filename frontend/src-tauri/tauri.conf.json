{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Meetily Improved",
    "version": "0.5.0",
    "identifier": "com.meetily.ai",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3118",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "windows": [
            {
                "title": "Meetily Improved",
                "width": 1280,
                "height": 820,
                "minWidth": 1100,
                "minHeight": 720,
                "resizable": true,
                "fullscreen": false,
                "theme": "Light",
                "decorations": true
            }
        ],
        "security": {
            "csp": {
                "default-src": "'self'",
                "base-uri": "'self'",
                "connect-src": "'self' ipc: http://ipc.localhost",
                "font-src": "'self' data:",
                "form-action": "'self'",
                "frame-ancestors": "'none'",
                "img-src": "'self' data:",
                "object-src": "'none'",
                "script-src": "'self'",
                "style-src": "'self' 'unsafe-inline'",
                "media-src": "'self' blob: data:"
            },
            "devCsp": {
                "default-src": "'self'",
                "base-uri": "'self'",
                "connect-src": "'self' ipc: http://ipc.localhost http://localhost:3118 ws://localhost:3118",
                "font-src": "'self' data:",
                "form-action": "'self'",
                "frame-ancestors": "'none'",
                "img-src": "'self' data:",
                "object-src": "'none'",
                "script-src": "'self'",
                "style-src": "'self' 'unsafe-inline'",
                "media-src": "'self' blob: data:"
            },
            "capabilities": [
                {
                    "identifier": "main",
                    "description": "Least-privilege capability for the shipped main window",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "main-window-commands",
                        "core:app:allow-version",
                        "core:event:allow-listen",
                        "core:event:allow-unlisten",
                        "core:path:allow-resolve-directory",
                        "core:resources:allow-close",
                        "store:allow-load",
                        "store:allow-get",
                        "store:allow-has",
                        "store:allow-set",
                        "store:allow-save",
                        "updater:allow-check",
                        "updater:allow-download",
                        "updater:allow-install",
                        "updater:allow-download-and-install",
                        "process:allow-restart",
                        "os:allow-platform"
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "appimage",
            "msi",
            "nsis",
            "app",
            "dmg"
        ],
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/icon.png",
            "icons/app_icon.icns",
            "icons/app_icon.ico"
        ],
        "resources": [
            "templates/*.json"
        ],
        "externalBin": [
            "binaries/llama-helper",
            "binaries/ffmpeg"
        ],
        "macOS": {
            "entitlements": "entitlements.plist",
            "infoPlist": "Info.plist",
            "signingIdentity": "-",
            "hardenedRuntime": true
        },
        "windows": {
            "signCommand": "powershell -ExecutionPolicy Bypass -File scripts/sign-windows.ps1 -FilePath %1"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDQTYzMUQ3ODc5N0M4MkEKUldRcXlKZUgxekdtN09DRkVWSHNpZlJseEVOUmpNd1dDSTNaLzZ3MXJGTnY3WW1pdnlOYjBpbkIK",
            "endpoints": [
                "https://github.com/henryvn27/meetily_improved/releases/latest/download/latest.json"
            ]
        }
    }
}
